{
  "permissions": {
    "allow": [
      "WebFetch(domain:docs.databricks.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:code.claude.com)"
    ]
  },
  "env": {
    // === AI Gateway 設定（システムエンドポイント） ===
    "ANTHROPIC_MODEL": "databricks-claude-opus-4-6",
    "ANTHROPIC_BASE_URL": "https://<AI_GATEWAY_ID>.ai-gateway.cloud.databricks.com/anthropic",
    "ANTHROPIC_AUTH_TOKEN": "<DATABRICKS_TOKEN>",
    "ANTHROPIC_CUSTOM_HEADERS": "x-databricks-use-coding-agent-mode: true",
    "CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS": "1",

    // === ユーザー定義エンドポイントを使う場合は上記の代わりに以下を使用 ===
    // "ANTHROPIC_MODEL": "<YOUR_ENDPOINT_NAME>",
    // "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    // "MAX_THINKING_TOKENS": "100000",

    // === Databricks 認証 ===
    "DATABRICKS_HOST": "https://<WORKSPACE>.cloud.databricks.com",
    "DATABRICKS_TOKEN": "<DATABRICKS_TOKEN>",

    // === Method 1: MLflow Tracing ===
    "MLFLOW_CLAUDE_TRACING_ENABLED": "true",
    "MLFLOW_TRACKING_URI": "databricks",
    "MLFLOW_EXPERIMENT_NAME": "/Users/<EMAIL>/claude-code-tracing"

    // === Method 2: OTEL Table（有効化する場合はコメント解除） ===
    // "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    // "OTEL_METRICS_EXPORTER": "otlp",
    // "OTEL_EXPORTER_OTLP_METRICS_PROTOCOL": "http/protobuf",
    // "OTEL_EXPORTER_OTLP_METRICS_ENDPOINT": "https://<WORKSPACE>.cloud.databricks.com/api/2.0/otel/v1/metrics",
    // "OTEL_EXPORTER_OTLP_METRICS_HEADERS": "content-type=application/x-protobuf,Authorization=Bearer <DATABRICKS_TOKEN>,X-Databricks-UC-Table-Name=<CATALOG>.<SCHEMA>.<PREFIX>_otel_metrics",
    // "OTEL_METRIC_EXPORT_INTERVAL": "10000",
    // "OTEL_LOGS_EXPORTER": "otlp",
    // "OTEL_EXPORTER_OTLP_LOGS_PROTOCOL": "http/protobuf",
    // "OTEL_EXPORTER_OTLP_LOGS_ENDPOINT": "https://<WORKSPACE>.cloud.databricks.com/api/2.0/otel/v1/logs",
    // "OTEL_EXPORTER_OTLP_LOGS_HEADERS": "content-type=application/x-protobuf,Authorization=Bearer <DATABRICKS_TOKEN>,X-Databricks-UC-Table-Name=<CATALOG>.<SCHEMA>.<PREFIX>_otel_logs",
    // "OTEL_LOGS_EXPORT_INTERVAL": "5000",
    // "OTEL_LOG_USER_PROMPTS": "1"
  },
  "hooks": {
    // Method 1: MLflow Tracing hook
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".venv/bin/python -c \"from mlflow.claude_code.hooks import stop_hook_handler; stop_hook_handler()\""
          }
        ]
      }
    ]
  },
  "environment": {
    "MLFLOW_CLAUDE_TRACING_ENABLED": "true",
    "MLFLOW_EXPERIMENT_NAME": "/Users/<EMAIL>/claude-code-tracing"
  }
}
