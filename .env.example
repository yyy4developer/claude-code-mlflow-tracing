# Unity Catalog location for OTEL tables (Method 2)
UC_CATALOG=your_catalog
UC_SCHEMA=your_schema

# MLflow experiment path (Method 1)
MLFLOW_EXPERIMENT_NAME=/Users/your-email@databricks.com/claude-code-tracing
